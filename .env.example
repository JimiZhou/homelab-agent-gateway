GATEWAY_PORT=8088
PUBLIC_MODEL=homelab-agent
LLM_MODEL=local-text
VISION_MODEL=local-vision

# OpenAI-compatible upstreams. For host services, keep host.docker.internal.
MODEL_UPSTREAMS=local-text=http://host.docker.internal:8001/v1,local-vision=http://host.docker.internal:8002/v1

ENABLE_VISION_FUSION=true
ENABLE_AUTO_CONTEXT=true
ENABLE_COMMERCIAL_FALLBACK=false

# Set before exposing the gateway outside localhost/LAN.
GATEWAY_API_KEY=

# Optional paid-model fallback.
COMMERCIAL_FALLBACK_BASE_URL=
COMMERCIAL_FALLBACK_MODEL=
COMMERCIAL_FALLBACK_API_KEY=
COMMERCIAL_FALLBACK_POLICY=error_or_empty
